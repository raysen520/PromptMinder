{
  "name": "prompt-minder",
  "version": "0.2.1",
  "private": true,
  "bin": {
    "promptminder": "./bin/promptminder.js"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "analyze": "ANALYZE=true next build",
    "analyze:server": "BUNDLE_ANALYZE=server next build",
    "analyze:browser": "BUNDLE_ANALYZE=browser next build",
    "build:analyze": "npm run build && npm run analyze",
    "performance:test": "node scripts/performance-test.js",
    "css:analyze": "node scripts/css-optimization.js",
    "css:optimize": "npm run css:analyze && tailwindcss -i ./app/globals.css -o ./app/globals.optimized.css --minify",
    "build:optimized": "npm run css:optimize && next build",
    "db:generate": "drizzle-kit generate --config drizzle.config.mjs",
    "db:migrate": "node drizzle/migrate.js",
    "db:baseline": "node drizzle/migrate.js --baseline",
    "db:push": "drizzle-kit push --config drizzle.config.mjs",
    "db:studio": "drizzle-kit studio --config drizzle.config.mjs",
    "cli": "node ./bin/promptminder.js",
    "cli:link": "pnpm link --global",
    "cli:unlink": "pnpm unlink --global",
    "cli:agent": "node ./scripts/promptminder-agent.js",
    "cli:pack": "npm pack ./packages/promptminder-cli",
    "cli:token": "node ./scripts/create-cli-token.js",
    "cli:whoami": "node ./scripts/cli-whoami.js"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.88",
    "@anthropic-ai/sdk": "^0.32.1",
    "@clerk/localizations": "^3.9.5",
    "@clerk/nextjs": "^6.23.3",
    "@clerk/themes": "^2.2.3",
    "@heroicons/react": "^2.2.0",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@radix-ui/react-visually-hidden": "^1.2.0",
    "@supabase/supabase-js": "^2.46.2",
    "@vercel/analytics": "^1.4.1",
    "ai": "^6.0.86",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "diff": "^5.1.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.294.0",
    "next": "16.1.5",
    "next-pwa": "^5.6.0",
    "openai": "^4.77.0",
    "postgres": "^3.4.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-markdown": "^9.0.1",
    "react-select": "^5.8.3",
    "react-syntax-highlighter": "^15.6.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.0.7",
    "@tailwindcss/typography": "^0.5.15",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "mini-css-extract-plugin": "^2.9.2",
    "msw": "^2.10.4",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "webpack-bundle-analyzer": "^4.10.2"
  }
}
